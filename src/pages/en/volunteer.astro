---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Volunteer Work">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Volunteer Work
    </h1>

    <p class="text-lg text-gray-700 dark:text-gray-300 mb-12">
        I'm passionate about giving back to the community and supporting open
        source projects.
    </p>

    <div class="space-y-8">
        <!-- Timeline Row 1 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    Period
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Open Source Contributions
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Contributing to open source projects and communities.
                </p>
            </div>
        </div>

        <!-- Timeline Row 2 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    Period
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Community Work
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Mentoring and helping others in the tech community.
                </p>
            </div>
        </div>
    </div>
</BaseLayout>
