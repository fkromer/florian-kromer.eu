---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Volunteer Work">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Volunteer Work
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            I'm passionate about giving back to the community and supporting
            open source projects.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Open Source Contributions
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Contributing to open source projects and communities.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Community Work
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Mentoring and helping others in the tech community.
            </p>
        </section>
    </div>
</BaseLayout>
