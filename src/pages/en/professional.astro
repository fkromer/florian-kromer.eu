---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Professional Activity">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Professional Activity
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            I work as an Embedded Linux Systems Architect with expertise in
            software development, systems design, and technical leadership.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Experience
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Specializing in embedded Linux systems, software architecture,
                and cross-functional team leadership.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Skills
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Embedded Linux, Systems Architecture, Software Development, Team
                Leadership, and Problem Solving.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Projects
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Leading and contributing to various technical projects and
                initiatives.
            </p>
        </section>
    </div>
</BaseLayout>
