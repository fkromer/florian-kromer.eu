---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Club Memberships">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Club Memberships
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            I am a member of various professional associations and organizations
            that support my professional development and engagement in the
            technology and engineering community.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Association Memberships
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Active memberships in various organizations to foster
                professional expertise and networking.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Professional Networks
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Participation in professional communities and networks for
                knowledge exchange and collaboration with colleagues.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Certifications and Qualifications
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Recognition and certificates from professional organizations and
                educational institutions.
            </p>
        </section>
    </div>
</BaseLayout>
