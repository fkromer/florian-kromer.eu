---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Club Memberships">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Club Memberships
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            I have been an active club member in sports and outdoor-related
            clubs since my youth.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Sports Club Memberships
            </h2>
            <div class="space-y-4 mb-8">
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2025–today
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            SSC Jachenau e.V.
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership. Ski club for Nordic and Alpine
                            skiing with mountain biking section.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2005–today
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            German Alpine Club (DAV)
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership in various regional sections of
                            the German Alpine Club.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2008–2011
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            Enshin Dojo Freiburg, Mu-Shin e.V.
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership. Full-contact Enshin Karate and
                            Muay-Thai Boxing.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2006–2007
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            University Sports Shotokan Karate
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership. Semi-contact in the German Karate
                            Association (DKV).
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2005–2006
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            University Sports Taekwondo Department
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership. Semi-contact Taekwondo in WAKO
                            BWKBV e.V.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2005–2006
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            University Sports Krav Maga
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership. Self defense.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            1998–2003
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            Football Club
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership in the football club from C-Youth
                            to A-Youth.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>
