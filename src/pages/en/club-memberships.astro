---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Club Memberships">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Club Memberships
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            I am a member of various professional associations and organizations
            that support my professional development and engagement in the
            technology and engineering community.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Sports Club Memberships
            </h2>
            <div class="space-y-4 mb-8">
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            2005–today
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            German Alpine Club (DAV)
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Membership in various regional sections of the
                            German Alpine Club.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-12 gap-4 items-start">
                    <div class="col-span-2">
                        <div
                            class="text-xl font-bold text-gray-900 dark:text-white"
                        >
                            1998–2003
                        </div>
                    </div>
                    <div class="col-span-10">
                        <h3
                            class="text-lg font-semibold text-gray-800 dark:text-gray-100 mb-1"
                        >
                            Football Club
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400">
                            Active membership in the football club from C-Youth
                            to A-Youth.
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>
