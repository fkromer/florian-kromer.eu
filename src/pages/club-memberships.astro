---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Vereinsmitgliedschaften">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Vereinsmitgliedschaften
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            Ich bin Mitglied in verschiedenen Fachverbänden und Organisationen,
            die meine berufliche Entwicklung und mein Engagement in der
            Technologie- und Ingenieur-Community unterstützen.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Verbandsmitgliedschaften
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Aktive Mitgliedschaften in verschiedenen Organisationen zur
                Förderung von Fachkompetenz und Netzwerken.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Professionelle Netzwerke
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Teilnahme an Fachgemeinschaften und Netzwerken zur
                Wissensaustausch und Zusammenarbeit mit Kollegen.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Zertifizierungen und Qualifikationen
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Anerkennung und Zertifikate von Fachorganisationen und
                Bildungsinstitutionen.
            </p>
        </section>
    </div>
</BaseLayout>
