---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Vereinsmitgliedschaften">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Vereinsmitgliedschaften
    </h1>

    <p class="text-lg text-gray-700 dark:text-gray-300 mb-12">
        Ich bin Mitglied in verschiedenen Fachverbänden und Organisationen, die
        meine berufliche Entwicklung und mein Engagement in der Technologie- und
        Ingenieur-Community unterstützen.
    </p>

    <div class="space-y-8">
        <!-- Timeline Row 1 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    2005–heute
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Deutscher Alpenverein (DAV)
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Mitgliedschaft in verschiedenen regionalen Sektionen des
                    Deutschen Alpenvereins.
                </p>
            </div>
        </div>

        <!-- Timeline Row 2 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    2006–2007
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Deutscher Karate Verband e.V.
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Semi-Kontakt Shotokan Karate.
                </p>
            </div>
        </div>

        <!-- Timeline Row 3 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    2006
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Hochschulsport Abteilung Taekwondo
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Teilnahme am Hochschulsport Taekwondo.
                </p>
            </div>
        </div>

        <!-- Timeline Row 4 -->
        <div class="grid grid-cols-12 gap-4 items-start">
            <div class="col-span-2">
                <div class="text-2xl font-bold text-gray-900 dark:text-white">
                    1998–2003
                </div>
            </div>
            <div class="col-span-10">
                <h3
                    class="text-xl font-semibold text-gray-800 dark:text-gray-100 mb-2"
                >
                    Fussballverein
                </h3>
                <p class="text-gray-600 dark:text-gray-400">
                    Aktive Mitgliedschaft im Fussballverein von der C-Jugend bis
                    zur A-Jugend.
                </p>
            </div>
        </div>
    </div>
</BaseLayout>
