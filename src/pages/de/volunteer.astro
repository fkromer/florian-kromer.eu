---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Ehrenamtliche Arbeit">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Ehrenamtliche Arbeit
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            Ich bin leidenschaftlich daran interessiert, der Gemeinschaft etwas
            zurückzugeben und Open-Source-Projekte zu unterstützen.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Open-Source-Beiträge
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Beitrag zu Open-Source-Projekten und Gemeinschaften.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Gemeinschaftsarbeit
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Mentoring und Unterstützung der Tech-Community.
            </p>
        </section>
    </div>
</BaseLayout>
