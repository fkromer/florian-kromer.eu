---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Berufliche Aktivitäten">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 dark:text-white">
        Berufliche Aktivitäten
    </h1>

    <div class="prose dark:prose-invert max-w-none">
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            Ich arbeite als Embedded Linux Systems Architect mit Fachkompetenz
            in Softwareentwicklung, Systemdesign und technischer Führung.
        </p>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Erfahrung
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Spezialisiert auf Embedded Linux Systeme, Softwarearchitektur
                und funktionsübergreifende Teamleitung.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Fähigkeiten
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Embedded Linux, Systemarchitektur, Softwareentwicklung,
                Teamleitung und Problemlösung.
            </p>
        </section>

        <section class="mb-12">
            <h2
                class="text-2xl font-bold mb-4 text-gray-800 dark:text-gray-100"
            >
                Projekte
            </h2>
            <p class="text-gray-600 dark:text-gray-400 mb-4">
                Leitung und Beitrag zu verschiedenen technischen Projekten und
                Initiativen.
            </p>
        </section>
    </div>
</BaseLayout>
